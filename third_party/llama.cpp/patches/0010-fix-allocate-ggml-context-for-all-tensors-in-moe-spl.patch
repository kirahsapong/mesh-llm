From fd93fa021da4b1575f2401b844b2c1e0cd1984f9 Mon Sep 17 00:00:00 2001
From: Ventz Petkov <ventz@vpetkov.net>
Date: Fri, 17 Apr 2026 01:39:26 -0400
Subject: [PATCH 10/15] fix: allocate ggml context for all tensors in
 moe-split, not just experts

The write_group() context was sized for n_expert_tensors but the loop
adds all n_tensors (trunk + experts). For models where total tensors far
exceed expert tensors (e.g. GLM-5.1: 1809 total vs 237 expert), the
context overflows at the last block causing SIGABRT.

Use n_tensors (already in scope from line 382) instead of
n_expert_tensors for the allocation.
---
 tools/moe-split/moe-split.cpp | 8 ++++++--
 1 file changed, 6 insertions(+), 2 deletions(-)

diff --git a/tools/moe-split/moe-split.cpp b/tools/moe-split/moe-split.cpp
index c950f5695..5a7df76de 100644
--- a/tools/moe-split/moe-split.cpp
+++ b/tools/moe-split/moe-split.cpp
@@ -403,8 +403,12 @@ static void write_group(
         }
     }
 
-    // Create ggml context for sliced tensors
-    size_t ctx_size = (size_t)(n_expert_tensors + 64) * ggml_tensor_overhead() + 4096;
+    // Create ggml context for ALL tensors (trunk + experts).
+    // Previously used n_expert_tensors which underallocated for models where the
+    // total tensor count far exceeds the expert tensor count (e.g. GLM-5.1 has
+    // 1809 total tensors but only ~237 expert tensors), causing SIGABRT at the
+    // last block when the context overflows.
+    size_t ctx_size = (size_t)(n_tensors + 64) * ggml_tensor_overhead() + 4096;
     struct ggml_init_params ctx_params = {
         /*.mem_size   =*/ ctx_size,
         /*.mem_buffer =*/ nullptr,
