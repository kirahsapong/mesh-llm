From a0a77d5f1ef5ee253c7613c47977f52c24697e64 Mon Sep 17 00:00:00 2001
From: James Dumay <jameswdumay@gmail.com>
Date: Fri, 17 Apr 2026 16:38:05 +1000
Subject: [PATCH 12/15] Make moe-split outputs standalone GGUFs

---
 tools/moe-split/moe-split.cpp | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/tools/moe-split/moe-split.cpp b/tools/moe-split/moe-split.cpp
index 64ebbdd4b..5b7f6b6f7 100644
--- a/tools/moe-split/moe-split.cpp
+++ b/tools/moe-split/moe-split.cpp
@@ -469,6 +469,11 @@ static void write_group(
     auto * ctx_out = gguf_init_empty();
     gguf_set_kv(ctx_out, ctx_in);
 
+    // MoE split outputs are standalone derived GGUFs, not members of the
+    // original upstream split set.
+    gguf_remove_key(ctx_out, "split.no");
+    gguf_remove_key(ctx_out, "split.count");
+    gguf_remove_key(ctx_out, "split.tensors.count");
     // Find architecture
     int arch_key = gguf_find_key(ctx_in, "general.architecture");
     std::string arch_name;
